<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:bpsim="http://www.bpsim.org/schemas/1.0" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:drools="http://www.jboss.org/drools" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="_ComplexServiceExample" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd http://www.jboss.org/drools drools.xsd http://www.bpsim.org/schemas/1.0 bpsim.xsd http://www.omg.org/spec/DD/20100524/DC DC.xsd http://www.omg.org/spec/DD/20100524/DI DI.xsd " exporter="jBPM Process Modeler" exporterVersion="2.0" targetNamespace="http://www.omg.org/bpmn20">
  <bpmn2:itemDefinition id="_externalTaskItem" structureRef="de.cib.kogito.worker.cibs.dto.ExternalTaskDto"/>
  <bpmn2:itemDefinition id="_inputVariablesItem" structureRef="java.util.Map&lt;String,Object&gt;"/>
  <bpmn2:itemDefinition id="_taskIdItem" structureRef="String"/>
  <bpmn2:itemDefinition id="_outputVariablesItem" structureRef="java.util.Map&lt;String,Object&gt;"/>
  <bpmn2:itemDefinition id="_CSE_InMessageType" structureRef=""/>
  <bpmn2:itemDefinition id="_CSE_OutMessageType" structureRef=""/>
  <bpmn2:itemDefinition id="__CSE_inputVariablesJavaObjectInputXItem" structureRef="Object"/>
  <bpmn2:itemDefinition id="__CSE_variablesOutputXItem" structureRef="java.util.Map&lt;String,Object&gt;"/>
  <bpmn2:message id="_CSE_InMessage" itemRef="_CSE_InMessageType"/>
  <bpmn2:message id="_CSE_OutMessage" itemRef="_CSE_OutMessageType"/>
  <bpmn2:interface id="_CSE_ServiceInterface" name="de.cib.kogito.worker.service.ServiceExample" implementationRef="de.cib.kogito.worker.service.ServiceExample">
    <bpmn2:operation id="_CSE_ServiceOperation" name="doSomething" implementationRef="doSomething">
      <bpmn2:inMessageRef>_CSE_InMessage</bpmn2:inMessageRef>
      <bpmn2:outMessageRef>_CSE_OutMessage</bpmn2:outMessageRef>
    </bpmn2:operation>
  </bpmn2:interface>
  <bpmn2:collaboration id="_CSE_Collab" name="Default Collaboration">
    <bpmn2:participant id="_CSE_Participant" name="Pool Participant" processRef="ComplexServiceExample"/>
  </bpmn2:collaboration>
  <bpmn2:process id="ComplexServiceExample" drools:packageName="de.cib.kogito.worker" drools:version="1.0" drools:adHoc="false" name="ComplexServiceExample" isExecutable="true" processType="Public">
    <bpmn2:property id="externalTask" itemSubjectRef="_externalTaskItem" name="externalTask">
      <bpmn2:extensionElements>
        <drools:metaData name="customTags"><drools:metaValue><![CDATA[input]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
    </bpmn2:property>
    <bpmn2:property id="inputVariables" itemSubjectRef="_inputVariablesItem" name="inputVariables">
      <bpmn2:extensionElements>
        <drools:metaData name="customTags"><drools:metaValue><![CDATA[input]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
    </bpmn2:property>
    <bpmn2:property id="taskId" itemSubjectRef="_taskIdItem" name="taskId">
      <bpmn2:extensionElements>
        <drools:metaData name="customTags"><drools:metaValue><![CDATA[input]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
    </bpmn2:property>
    <bpmn2:property id="outputVariables" itemSubjectRef="_outputVariablesItem" name="outputVariables">
      <bpmn2:extensionElements>
        <drools:metaData name="customTags"><drools:metaValue><![CDATA[output]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
    </bpmn2:property>
    <bpmn2:sequenceFlow id="Flow_CSE_0" sourceRef="_CSE_Start" targetRef="_CSE_ScriptTask"/>
    <bpmn2:sequenceFlow id="Flow_CSE_1" sourceRef="_CSE_ScriptTask" targetRef="_CSE_ServiceTask"/>
    <bpmn2:sequenceFlow id="Flow_CSE_2" sourceRef="_CSE_ServiceTask" targetRef="_CSE_End"/>
    <bpmn2:startEvent id="_CSE_Start" name="Service Start">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[Service Start]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:outgoing>Flow_CSE_0</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:scriptTask id="_CSE_ScriptTask" name="log inputs" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[log inputs]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_CSE_0</bpmn2:incoming>
      <bpmn2:outgoing>Flow_CSE_1</bpmn2:outgoing>
      <bpmn2:script>System.out.println("inputVariables: " + inputVariables);
System.out.println("taskId: " + taskId);
</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:serviceTask id="_CSE_ServiceTask" drools:serviceimplementation="Java" drools:serviceinterface="de.cib.kogito.worker.service.ServiceExample" drools:serviceoperation="doSomething" name="do something with a service" implementation="Java" operationRef="_CSE_ServiceOperation">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[do something with a service]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_CSE_1</bpmn2:incoming>
      <bpmn2:outgoing>Flow_CSE_2</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="_CSE_ServiceTask_inputX" drools:dtype="Object" itemSubjectRef="__CSE_inputVariablesJavaObjectInputXItem" name="inputVariablesJavaObject"/>
        <bpmn2:dataOutput id="_CSE_ServiceTask_outputX" drools:dtype="java.util.Map&lt;String*Object&gt;" itemSubjectRef="__CSE_variablesOutputXItem" name="variables"/>
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>_CSE_ServiceTask_inputX</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet>
          <bpmn2:dataOutputRefs>_CSE_ServiceTask_outputX</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>inputVariables</bpmn2:sourceRef>
        <bpmn2:targetRef>_CSE_ServiceTask_inputX</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>_CSE_ServiceTask_outputX</bpmn2:sourceRef>
        <bpmn2:targetRef>outputVariables</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:serviceTask>
    <bpmn2:endEvent id="_CSE_End" name="Service fulfilled">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[Service fulfilled]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_CSE_2</bpmn2:incoming>
    </bpmn2:endEvent>
  </bpmn2:process>
  <bpmndi:BPMNDiagram>
    <bpmndi:BPMNPlane bpmnElement="ComplexServiceExample">
      <bpmndi:BPMNShape id="shape__CSE_Start" bpmnElement="_CSE_Start">
        <dc:Bounds height="56" width="56" x="158" y="101"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__CSE_ScriptTask" bpmnElement="_CSE_ScriptTask">
        <dc:Bounds height="102" width="154" x="280" y="78"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__CSE_ServiceTask" bpmnElement="_CSE_ServiceTask">
        <dc:Bounds height="102" width="154" x="510" y="78"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__CSE_End" bpmnElement="_CSE_End">
        <dc:Bounds height="56" width="56" x="740" y="101"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge_CSE_0" bpmnElement="Flow_CSE_0">
        <di:waypoint x="214" y="129"/>
        <di:waypoint x="280" y="129"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_CSE_1" bpmnElement="Flow_CSE_1">
        <di:waypoint x="434" y="129"/>
        <di:waypoint x="510" y="129"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_CSE_2" bpmnElement="Flow_CSE_2">
        <di:waypoint x="664" y="129"/>
        <di:waypoint x="740" y="129"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>
