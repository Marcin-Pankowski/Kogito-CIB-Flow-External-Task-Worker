<?xml version="1.0" encoding="UTF-8"?>
<!--
  ShortPollHandlerExample — handles one CIB Seven external task.

  Receives an ExternalTaskDto (activatedJob), extracts its variables,
  calls ComplexServiceExample, then completes the task in CIB Seven.
-->
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:bpsim="http://www.bpsim.org/schemas/1.0" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:drools="http://www.jboss.org/drools" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="_ShortPollHandlerExample" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd http://www.jboss.org/drools drools.xsd http://www.bpsim.org/schemas/1.0 bpsim.xsd http://www.omg.org/spec/DD/20100524/DC DC.xsd http://www.omg.org/spec/DD/20100524/DI DI.xsd " exporter="jBPM Process Modeler" exporterVersion="2.0" targetNamespace="http://www.omg.org/bpmn20">
  <bpmn2:itemDefinition id="_taskIdItem" structureRef="String"/>
  <bpmn2:itemDefinition id="_outputVariablesItem" structureRef="Object"/>
  <!-- activatedJob is the ExternalTaskDto passed in by the multi-instance loop -->
  <bpmn2:itemDefinition id="_activatedJobItem" structureRef="de.cib.kogito.worker.cibs.dto.ExternalTaskDto"/>
  <bpmn2:itemDefinition id="_inputVariablesItem" structureRef="java.util.Map&lt;String,Object&gt;"/>
  <!-- call activity I/O items -->
  <bpmn2:itemDefinition id="__CA_inputVariablesInputXItem" structureRef="Object"/>
  <bpmn2:itemDefinition id="__CA_taskIdInputXItem" structureRef="String"/>
  <bpmn2:itemDefinition id="__CA_outputVariablesOutputXItem" structureRef="Object"/>
  <!-- complete service task I/O items -->
  <bpmn2:itemDefinition id="_SPH_InMessageType" structureRef=""/>
  <bpmn2:itemDefinition id="_SPH_OutMessageType" structureRef=""/>
  <bpmn2:itemDefinition id="__SPH_taskIdInputXItem" structureRef="String"/>
  <bpmn2:itemDefinition id="__SPH_variablesInputXItem" structureRef="Object"/>
  <bpmn2:message id="_SPH_InMessage" itemRef="_SPH_InMessageType"/>
  <bpmn2:message id="_SPH_OutMessage" itemRef="_SPH_OutMessageType"/>
  <!-- Interface pointing at CibSevenFunctions.complete -->
  <bpmn2:interface id="_SPH_ServiceInterface" name="de.cib.kogito.worker.cibs.CibSevenFunctions" implementationRef="de.cib.kogito.worker.cibs.CibSevenFunctions">
    <bpmn2:operation id="_SPH_ServiceOperation" name="complete" implementationRef="complete">
      <bpmn2:inMessageRef>_SPH_InMessage</bpmn2:inMessageRef>
      <bpmn2:outMessageRef>_SPH_OutMessage</bpmn2:outMessageRef>
    </bpmn2:operation>
  </bpmn2:interface>
  <bpmn2:collaboration id="_SPH_Collab" name="Default Collaboration">
    <bpmn2:participant id="_SPH_Participant" name="Pool Participant" processRef="ShortPollHandlerExample"/>
  </bpmn2:collaboration>
  <bpmn2:process id="ShortPollHandlerExample" drools:packageName="de.cib.kogito.worker" drools:version="1.0" drools:adHoc="false" name="ShortPollHandlerExample" isExecutable="true" processType="Private">
    <!-- taskId: CIB Seven external task ID (String — equivalent of Zeebe jobKey Long) -->
    <bpmn2:property id="taskId" itemSubjectRef="_taskIdItem" name="taskId">
      <bpmn2:extensionElements>
        <drools:metaData name="customTags"><drools:metaValue><![CDATA[internal]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
    </bpmn2:property>
    <bpmn2:property id="outputVariables" itemSubjectRef="_outputVariablesItem" name="outputVariables">
      <bpmn2:extensionElements>
        <drools:metaData name="customTags"><drools:metaValue><![CDATA[output]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
    </bpmn2:property>
    <!-- activatedJob: the ExternalTaskDto loop item passed from ShortPollWorkerExample -->
    <bpmn2:property id="activatedJob" itemSubjectRef="_activatedJobItem" name="activatedJob">
      <bpmn2:extensionElements>
        <drools:metaData name="customTags"><drools:metaValue><![CDATA[input]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
    </bpmn2:property>
    <bpmn2:property id="inputVariables" itemSubjectRef="_inputVariablesItem" name="inputVariables">
      <bpmn2:extensionElements>
        <drools:metaData name="customTags"><drools:metaValue><![CDATA[input]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
    </bpmn2:property>
    <!-- sequence flows -->
    <bpmn2:sequenceFlow id="_SPH_SF_0" sourceRef="_SPH_Start" targetRef="_SPH_PrepareVars"/>
    <bpmn2:sequenceFlow id="_SPH_SF_1" sourceRef="_SPH_PrepareVars" targetRef="_SPH_CallComplexService"/>
    <bpmn2:sequenceFlow id="_SPH_SF_2" sourceRef="_SPH_CallComplexService" targetRef="_SPH_CompleteTask"/>
    <bpmn2:sequenceFlow id="_SPH_SF_3" sourceRef="_SPH_CompleteTask" targetRef="_SPH_End"/>
    <!-- Start event -->
    <bpmn2:startEvent id="_SPH_Start" name="handle job">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[handle job]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:outgoing>_SPH_SF_0</bpmn2:outgoing>
    </bpmn2:startEvent>
    <!--
      Script task: extract taskId and inputVariables from the ExternalTaskDto.
      Mirrors the Zeebe template script:
        kcontext.setVariable("jobKey", activatedJob.getKey());
        kcontext.setVariable("inputVariables", activatedJob.getVariablesAsMap());
    -->
    <bpmn2:scriptTask id="_SPH_PrepareVars" name="prepare Variables" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[prepare Variables]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_SPH_SF_0</bpmn2:incoming>
      <bpmn2:outgoing>_SPH_SF_1</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable("taskId", activatedJob.getId());
kcontext.setVariable("inputVariables", activatedJob.getVariablesAsMap());
</bpmn2:script>
    </bpmn2:scriptTask>
    <!-- Call activity: invoke ComplexServiceExample with inputVariables + taskId -->
    <bpmn2:callActivity id="_SPH_CallComplexService" drools:independent="false" drools:waitForCompletion="true" name="call complex service" calledElement="ComplexServiceExample">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[call complex service]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_SPH_SF_1</bpmn2:incoming>
      <bpmn2:outgoing>_SPH_SF_2</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="_SPH_CA_inputVariablesInputX" drools:dtype="Object" itemSubjectRef="__CA_inputVariablesInputXItem" name="inputVariables"/>
        <bpmn2:dataInput id="_SPH_CA_taskIdInputX" drools:dtype="String" itemSubjectRef="__CA_taskIdInputXItem" name="taskId"/>
        <bpmn2:dataOutput id="_SPH_CA_outputVariablesOutputX" drools:dtype="Object" itemSubjectRef="__CA_outputVariablesOutputXItem" name="outputVariables"/>
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>_SPH_CA_inputVariablesInputX</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>_SPH_CA_taskIdInputX</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet>
          <bpmn2:dataOutputRefs>_SPH_CA_outputVariablesOutputX</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>inputVariables</bpmn2:sourceRef>
        <bpmn2:targetRef>_SPH_CA_inputVariablesInputX</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>taskId</bpmn2:sourceRef>
        <bpmn2:targetRef>_SPH_CA_taskIdInputX</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>_SPH_CA_outputVariablesOutputX</bpmn2:sourceRef>
        <bpmn2:targetRef>outputVariables</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:callActivity>
    <!-- Service task: call CibSevenFunctions.complete(taskId, variables) -->
    <bpmn2:serviceTask id="_SPH_CompleteTask" drools:serviceimplementation="Java" drools:serviceinterface="de.cib.kogito.worker.cibs.CibSevenFunctions" drools:serviceoperation="complete" name="complete job" implementation="Java" operationRef="_SPH_ServiceOperation">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[complete job]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_SPH_SF_2</bpmn2:incoming>
      <bpmn2:outgoing>_SPH_SF_3</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="_SPH_taskIdInputX" drools:dtype="String" itemSubjectRef="__SPH_taskIdInputXItem" name="taskId"/>
        <bpmn2:dataInput id="_SPH_variablesInputX" drools:dtype="Object" itemSubjectRef="__SPH_variablesInputXItem" name="variables"/>
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>_SPH_taskIdInputX</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>_SPH_variablesInputX</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>taskId</bpmn2:sourceRef>
        <bpmn2:targetRef>_SPH_taskIdInputX</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>outputVariables</bpmn2:sourceRef>
        <bpmn2:targetRef>_SPH_variablesInputX</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
    </bpmn2:serviceTask>
    <bpmn2:endEvent id="_SPH_End" name="job handled">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname"><drools:metaValue><![CDATA[job handled]]></drools:metaValue></drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_SPH_SF_3</bpmn2:incoming>
    </bpmn2:endEvent>
  </bpmn2:process>
  <bpmndi:BPMNDiagram>
    <bpmndi:BPMNPlane bpmnElement="ShortPollHandlerExample">
      <bpmndi:BPMNShape id="shape__SPH_Start" bpmnElement="_SPH_Start">
        <dc:Bounds height="56" width="56" x="160" y="174"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__SPH_PrepareVars" bpmnElement="_SPH_PrepareVars">
        <dc:Bounds height="102" width="154" x="280" y="151"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__SPH_CallComplexService" bpmnElement="_SPH_CallComplexService">
        <dc:Bounds height="102" width="154" x="510" y="151"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__SPH_CompleteTask" bpmnElement="_SPH_CompleteTask">
        <dc:Bounds height="102" width="154" x="740" y="151"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__SPH_End" bpmnElement="_SPH_End">
        <dc:Bounds height="56" width="56" x="970" y="174"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge__SPH_SF_0" bpmnElement="_SPH_SF_0">
        <di:waypoint x="216" y="202"/>
        <di:waypoint x="280" y="202"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge__SPH_SF_1" bpmnElement="_SPH_SF_1">
        <di:waypoint x="434" y="202"/>
        <di:waypoint x="510" y="202"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge__SPH_SF_2" bpmnElement="_SPH_SF_2">
        <di:waypoint x="664" y="202"/>
        <di:waypoint x="740" y="202"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge__SPH_SF_3" bpmnElement="_SPH_SF_3">
        <di:waypoint x="894" y="202"/>
        <di:waypoint x="970" y="202"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>
